{
  "name": "Translation Automation",
  "nodes": [
    {
      "parameters": {"httpMethod": "POST", "path": "translate", "responseMode": "lastNode"},
      "name": "Webhook Trigger", "type": "n8n-nodes-base.webhook", "typeVersion": 1, "position": [250, 300]
    },
    {
      "parameters": {
        "url": "https://api-free.deepl.com/v2/translate",
        "method": "POST",
        "authentication": "genericCredentialType",
        "sendHeaders": true,
        "headerParameters": {"parameters": [{"name": "Authorization", "value": "DeepL-Auth-Key $DEEPL_API_KEY"}]},
        "sendBody": "json",
        "bodyParameters": {
          "parameters": [
            {"name": "text", "value": "={{$json.content}}"},
            {"name": "target_lang", "value": "={{$json.target_lang}}"}
          ]
        },
        "options": {}
      },
      "name": "DeepL Translate", "type": "n8n-nodes-base.httpRequest", "typeVersion": 3, "position": [500, 300]
    },
    {
      "parameters": {
        "functionCode": "const result = $input.item.json;\nconst score = await require('ai-agent').scoreTranslation(result.original, result.translation);\nreturn [{json: {result, score}}];"
      },
      "name": "Quality Score", "type": "n8n-nodes-base.function", "position": [750, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": true, "typeValidation": "strict"},
          "conditions": [{"id": "score", "leftValue": "{{$json.score.overall}}", "rightValue": 70, "operator": {"type": "number", "operation": "lessThan"}}]
        }
      },
      "name": "Low Quality?", "type": "n8n-nodes-base.if", "position": [1000, 300]
    },
    {
      "parameters": {"channel": "translations-review", "text": "=⚠️ Low quality translation flagged: {{$json.result.original}}", "options": {}},
      "name": "Flag for Review", "type": "n8n-nodes-base.slack", "position": [1250, 200]
    },
    {
      "parameters": {"to": "={{$json.result.author_email}}", "subject": "Translation Complete: {{$json.result.target_lang}}", "options": {}},
      "name": "Email Author", "type": "n8n-nodes-base.emailReadImap", "position": [1250, 400]
    }
  ],
  "connections": {
    "Webhook Trigger": {"main": [[{"node": "DeepL Translate", "type": "main"}]]},
    "DeepL Translate": {"main": [[{"node": "Quality Score", "type": "main"}]]},
    "Quality Score": {"main": [[{"node": "Low Quality?", "type": "main"}]]},
    "Low Quality?": {"main": [[{"node": "Flag for Review", "type": "main"}], [{"node": "Email Author", "type": "main"}]]}
  }
}
