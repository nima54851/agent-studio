name = "lingxi-agent"
main = "src/index.ts"
compatibility_date = "2024-01-01"
account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"

[ai]
binding = "AI"

[[kv_namespaces]]
binding = "AGENT_MEMORY"
id = "YOUR_KV_NAMESPACE_ID"

[vars]
MODEL = "@cf/meta/llama-3-8b-instruct"
MAX_TOKENS = "2048"
AGENT_NAME = "灵犀 AI"

[limits]
cpu_ms = 50
memory_mb = 128
subrequests = 50

[triggers]
# Uncomment to bind a custom domain:
# routes = [
#   { pattern = "agent.yourdomain.com", zone_name = "yourdomain.com" }
# ]

[observability]
# Send logs to Cloudflare Logpush or wrangler tail
logpush = false
