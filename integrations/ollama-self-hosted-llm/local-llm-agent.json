{
  "name": "Ollama Local LLM Agent",
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "ollama-chat", "responseMode": "responseNode" },
      "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 1
    },
    {
      "parameters": {
        "url": "http://localhost:11434/api/chat",
        "method": "POST",
        "bodyParameters": {
          "parameters": [
            { "name": "model", "value": "={{ $json.body.model || 'llama3.2' }}" },
            { "name": "messages", "value": "={{ $json.body.messages }}" },
            { "name": "stream", "value": false }
          ]
        },
        "options": { "timeout": 120000 }
      },
      "name": "Ollama API", "type": "n8n-nodes-base.httpRequest", "typeVersion": 1
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Ollama API", "type": "main", "index": 0 }]] }
  }
}
