{
  "name": "A11y Automation",
  "nodes": [
    {
      "parameters": {"httpMethod": "POST", "path": "a11y-scan", "responseMode": "lastNode"},
      "name": "Webhook / GitHub PR", "type": "n8n-nodes-base.webhook", "typeVersion": 1, "position": [250, 300]
    },
    {
      "parameters": {
        "functionCode": "const { runAxeScan } = require('a11y-automation');\nconst url = $input.item.json.url;\nconst results = await runAxeScan(url);\nreturn [{json: {url, results}}];"
      },
      "name": "Run axe-core Scan", "type": "n8n-nodes-base.function", "position": [500, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {"typeValidation": "strict"},
          "conditions": [{"id": "violations", "leftValue": "={{$json.results.violations.length}}", "rightValue": 0, "operator": {"type": "number", "operation": "greaterThan"}}]
        }
      },
      "name": "Violations Found?", "type": "n8n-nodes-base.if", "position": [750, 300]
    },
    {
      "parameters": {
        "functionCode": "const violations = $input.item.json.results.violations;\nconst fixes = await Promise.all(violations.map(v => require('a11y-automation').generateFixSuggestion(v)));\nreturn [{json: {violations, fixes}}];"
      },
      "name": "Generate AI Fixes", "type": "n8n-nodes-base.function", "position": [1000, 300]
    },
    {
      "parameters": {
        "channel": "a11y-alerts",
        "text": "=♿ A11y Violations Found on {{$json.url}}\n={{$json.results.violations.length}} violations\n\nTop fix: {{$json.fixes[0]}}",
        "options": {}
      },
      "name": "Slack A11y Alert", "type": "n8n-nodes-base.slack", "position": [1250, 300]
    }
  ],
  "connections": {
    "Webhook / GitHub PR": {"main": [[{"node": "Run axe-core Scan", "type": "main"}]]},
    "Run axe-core Scan": {"main": [[{"node": "Violations Found?", "type": "main"}]]},
    "Violations Found?": {"main": [[{"node": "Generate AI Fixes", "type": "main"}], [{"node": "Slack A11y Alert", "type": "main"}]]},
    "Generate AI Fixes": {"main": [[{"node": "Slack A11y Alert", "type": "main"}]]}
  }
}
